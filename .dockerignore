# Build artifacts & deps (recreated inside the image)
node_modules
.next
out
build
coverage

# VCS & editor
.git
.gitignore
.github
.idea
.vscode
*.tsbuildinfo

# Docker / compose (not needed inside the image)
Dockerfile
docker-compose*.yml
.dockerignore

# Local env / secrets — build reads SITE_URL/SITE_NAME from build args, never
# from local files, so keep secrets out of the image.
.env*
!.env.example

# Misc
README.md
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.DS_Store
